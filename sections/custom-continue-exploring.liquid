{{ 'custom-continue-exploring.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .continue-exploring-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .continue-exploring-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="continue-exploring continue-exploring-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
      <div class="continue-exploring__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="collection__subtitle">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="section-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- liquid
      assign selected_blog = section.settings.blog
      assign article_limit = section.settings.article_limit
      assign display_count = 0
    -%}

    {%- if selected_blog != blank and selected_blog.articles.size > 0 -%}
      <div class="continue-exploring__grid">
        {%- for blog_article in selected_blog.articles -%}
          {%- if blog_article.id == article.id -%}
            {%- continue -%}
          {%- endif -%}
          {%- if display_count >= article_limit -%}
            {%- break -%}
          {%- endif -%}

          {%- liquid
            assign display_count = display_count | plus: 1
            assign index_padded = display_count
            if display_count < 10
              assign index_padded = '0' | append: display_count
            endif
            assign tile_alt = blog_article.title | strip_html | default: shop.name | escape
          -%}

          <a href="{{ blog_article.url }}" class="continue-exploring__item{% unless section.settings.grayscale_images %} continue-exploring__item--color{% endunless %}">
            <span class="continue-exploring__media">
              {%- if blog_article.image -%}
                {{
                  blog_article.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'continue-exploring__image',
                    alt: tile_alt,
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 25vw, 50vw',
                    widths: '275, 400, 550, 700, 800'
                }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'continue-exploring__image placeholder-svg' }}
              {%- endif -%}
              <span class="continue-exploring__number">{{ index_padded }}</span>
            </span>
            <span class="continue-exploring__content">
              <span class="continue-exploring__title rte">{{ blog_article.title }}</span>
              <span class="continue-exploring__arrow">
                <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
              </span>
            </span>
          </a>
        {%- endfor -%}
      </div>
    {%- elsif request.design_mode -%}
      <p class="continue-exploring__empty">Select a blog in the section settings to feature its articles.</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Continue Exploring",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Rituals"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Continue Exploring"
    },
    {
      "type": "header",
      "content": "Blog"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog",
      "info": "Articles from this blog populate the grid automatically."
    },
    {
      "type": "range",
      "id": "article_limit",
      "min": 1,
      "max": 12,
      "step": 1,
      "label": "Number of articles to show",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "grayscale_images",
      "label": "Grayscale images",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Continue Exploring"
    }
  ]
}
{% endschema %}
