{{ 'custom-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .custom-footer-{{ section.id }} {
    --custom-footer-accent: {{ section.settings.accent_color }};
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .custom-footer-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_social = false
  if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_tiktok_link != blank or settings.social_twitter_link != blank or settings.social_pinterest_link != blank or settings.social_snapchat_link != blank or settings.social_tumblr_link != blank or settings.social_vimeo_link != blank
    assign has_social = true
  endif
-%}

<footer class="custom-footer color-{{ section.settings.color_scheme }} gradient custom-footer-{{ section.id }}">
  <div class="custom-footer__inner page-width">
    <div class="custom-footer__icons">
      <span class="custom-footer__icon custom-footer__icon--one">
        {%- if section.settings.icon_one != blank -%}
          <img
            src="{{ section.settings.icon_one | image_url: width: 100 }}"
            alt=""
            width="{{ section.settings.icon_one.width }}"
            height="{{ section.settings.icon_one.height }}"
            loading="lazy"
          >
        {%- else -%}
          <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true" focusable="false">
            <circle cx="16" cy="9.5" r="6.5"/>
            <circle cx="16" cy="22.5" r="6.5"/>
            <circle cx="9.5" cy="16" r="6.5"/>
            <circle cx="22.5" cy="16" r="6.5"/>
          </svg>
        {%- endif -%}
      </span>

      <span class="custom-footer__icon custom-footer__icon--two">
        {%- if section.settings.icon_two != blank -%}
          <img
            src="{{ section.settings.icon_two | image_url: width: 100 }}"
            alt=""
            width="{{ section.settings.icon_two.width }}"
            height="{{ section.settings.icon_two.height }}"
            loading="lazy"
          >
        {%- else -%}
          <svg
            viewBox="0 0 32 32"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
            focusable="false"
          >
            <line x1="16" y1="3.5" x2="16" y2="10"/>
            <line x1="16" y1="22" x2="16" y2="28.5"/>
            <line x1="3.5" y1="16" x2="10" y2="16"/>
            <line x1="22" y1="16" x2="28.5" y2="16"/>
            <line x1="7" y1="7" x2="11.3" y2="11.3"/>
            <line x1="20.7" y1="20.7" x2="25" y2="25"/>
            <line x1="7" y1="25" x2="11.3" y2="20.7"/>
            <line x1="20.7" y1="11.3" x2="25" y2="7"/>
            <circle cx="16" cy="16" r="2.6" fill="currentColor" stroke="none"/>
          </svg>
        {%- endif -%}
      </span>

      <span class="custom-footer__icon custom-footer__icon--three">
        {%- if section.settings.icon_three != blank -%}
          <img
            src="{{ section.settings.icon_three | image_url: width: 100 }}"
            alt=""
            width="{{ section.settings.icon_three.width }}"
            height="{{ section.settings.icon_three.height }}"
            loading="lazy"
          >
        {%- else -%}
          <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true" focusable="false">
            <ellipse cx="16" cy="16" rx="3.4" ry="13" transform="rotate(45 16 16)"/>
            <ellipse cx="16" cy="16" rx="3.4" ry="13" transform="rotate(-45 16 16)"/>
          </svg>
        {%- endif -%}
      </span>
    </div>

    {%- if section.settings.heading_image != blank -%}
      <h2 class="custom-footer__brand custom-footer__brand--image">
        <img
          src="{{ section.settings.heading_image | image_url: width: 1600 }}"
          alt="{{ section.settings.heading | default: shop.name | escape }}"
          width="{{ section.settings.heading_image.width }}"
          height="{{ section.settings.heading_image.height }}"
          loading="lazy"
        >
      </h2>
    {%- elsif section.settings.heading != blank -%}
      <h2 class="custom-footer__brand">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 or section.settings.show_social and has_social -%}
      <div class="custom-footer__nav">
        {%- if section.blocks.size > 0 -%}
          <div class="custom-footer__lists">
            {%- for block in section.blocks -%}
              <div class="custom-footer__list-col" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <p class="custom-footer__list-heading">{{ block.settings.heading | escape }}</p>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="custom-footer__list" role="list">
                    {%- for link in block.settings.menu.links -%}
                      <li>
                        <a
                          href="{{ link.url }}"
                          class="custom-footer__link{% if link.active %} custom-footer__link--active{% endif %}"
                        >
                          {{ link.title | escape }}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_social and has_social -%}
          {%- render 'social-icons', class: 'custom-footer__social' -%}
        {%- endif -%}
      </div>
    {%- endif -%}

    <hr class="custom-footer__divider">

    <div class="custom-footer__bottom">
      <p class="custom-footer__copyright">
        &copy;{{ 'now' | date: '%Y' }}
        {{ shop.name -}}
        {%- if section.settings.copyright_text != blank %} - {{ section.settings.copyright_text }}{% endif %}
      </p>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Custom Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Top icons"
    },
    {
      "type": "image_picker",
      "id": "icon_one",
      "label": "Icon 1 (left)",
      "info": "Optional. Falls back to the built-in clover mark."
    },
    {
      "type": "image_picker",
      "id": "icon_two",
      "label": "Icon 2 (center)",
      "info": "Optional. Falls back to the built-in sun mark."
    },
    {
      "type": "image_picker",
      "id": "icon_three",
      "label": "Icon 3 (right)",
      "info": "Optional. Falls back to the built-in cross mark."
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "heading_image",
      "label": "Heading image",
      "info": "Replaces the heading text below with this image, e.g. a wordmark logo."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Bikaneri Kitchen",
      "info": "Shown as text when no heading image is set above. Also used as the image's alt text."
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social media icons",
      "default": true,
      "info": "Add your links in Theme settings > Social media."
    },
    {
      "type": "header",
      "content": "Copyright"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Text after store name",
      "default": "All Rights Reserved"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-e41ba56d-f51d-47f6-8e6e-e04c8cbcade2"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "info": "Used for icons, links, the social icon outline and the divider line.",
      "default": "#FF6344"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "info": "Optional. Leave blank to match the screenshot."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Choose a menu created in Shopify Navigation."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Custom Footer",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "menu": "main-menu"
          }
        },
        {
          "type": "menu"
        },
        {
          "type": "menu"
        }
      ]
    }
  ]
}
{% endschema %}
