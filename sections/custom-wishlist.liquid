{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{% comment %} Loaded after component-card.css so its rules always win on equal specificity {% endcomment %}
{{ 'card-product-shop.css' | asset_url | stylesheet_tag }}
{{ 'custom-wishlist.css' | asset_url | stylesheet_tag }}
{% comment %} Cards on this page are built client-side by wishlist.js from localStorage, so no add-to-cart form/JS is needed here. {% endcomment %}
<script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>

<div class="wishlist-page page-width">
  {%- if section.settings.heading != blank -%}
    <h1 class="wishlist-page__heading section-heading">{{ section.settings.heading | escape }}</h1>
  {%- endif -%}

  {%- comment -%}
    Wishlist contents live in the browser's localStorage (see wishlist.js), not
    Liquid — this list starts empty and is populated client-side on load.
  {%- endcomment -%}
  <ul class="grid product-grid grid--2-col-tablet-down grid--4-col-desktop" data-wishlist-page hidden></ul>

  <div class="wishlist-page__empty" data-wishlist-empty hidden>
    {%- if section.settings.empty_heading != blank -%}
      <h2 class="wishlist-page__empty-heading">{{ section.settings.empty_heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.empty_body != blank -%}
      <p class="wishlist-page__empty-body">{{ section.settings.empty_body | escape }}</p>
    {%- endif -%}
    {%- if section.settings.empty_button_label != blank -%}
      <a href="{{ routes.all_products_collection_url }}" class="button wishlist-page__empty-button">
        {{ section.settings.empty_button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Wishlist Page",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "header",
      "content": "Empty state"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Heading",
      "default": "Your wishlist is empty"
    },
    {
      "type": "text",
      "id": "empty_body",
      "label": "Text",
      "default": "Save products you love by tapping the heart icon on any product."
    },
    {
      "type": "text",
      "id": "empty_button_label",
      "label": "Button label",
      "default": "Continue Shopping"
    }
  ],
  "presets": [
    {
      "name": "Wishlist Page"
    }
  ]
}
{% endschema %}
