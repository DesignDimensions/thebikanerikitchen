{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{% comment %} Loaded after component-card.css so its rules always win on equal specificity {% endcomment %}
{{ 'card-product-shop.css' | asset_url | stylesheet_tag }}
{{ 'custom-wishlist.css' | asset_url | stylesheet_tag }}
{% comment %} Cards on this page are rebuilt client-side by wishlist.js from localStorage using the same shop-card markup as card-product-shop.liquid, so its companion JS (size-select price sync, add-to-cart form) is needed here too. {% endcomment %}
<script src="{{ 'card-product-shop.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<div class="wishlist-page page-width">
  {%- if section.settings.subheading != blank -%}
    <p class="clp-collection__subtitle">{{ section.settings.subheading | escape }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h1 class="wishlist-page__heading section-heading">{{ section.settings.heading | escape }}</h1>
  {%- endif -%}

  {%- comment -%}
    Wishlist contents live in the browser's localStorage (see wishlist.js), not
    Liquid — this list starts empty and is populated client-side on load.
    Grid columns match the collection page's product-grid section (2 desktop /
    2 tablet-down) so card width is identical.
  {%- endcomment -%}
  <ul class="grid product-grid grid--2-col-tablet-down grid--2-col-desktop" data-wishlist-page hidden></ul>

  {%- if section.settings.shop_more_label != blank -%}
    <a href="/collections/the-bhandaar" class="wishlist-page__shop-more" data-wishlist-shop-more hidden>
      {{ section.settings.shop_more_label | escape }}
    </a>
  {%- endif -%}

  <div class="wishlist-page__empty" data-wishlist-empty hidden>
    {%- if section.settings.empty_heading != blank -%}
      <h2 class="wishlist-page__empty-heading">{{ section.settings.empty_heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.empty_body != blank -%}
      <p class="wishlist-page__empty-body">{{ section.settings.empty_body | escape }}</p>
    {%- endif -%}
    {%- if section.settings.empty_button_label != blank -%}
      <a href="{{ routes.all_products_collection_url }}" class="button wishlist-page__empty-button">
        {{ section.settings.empty_button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Wishlist Page",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (eyebrow)",
      "default": "THE LIST"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "text",
      "id": "shop_more_label",
      "label": "\"Continue shopping\" link label (shown when the wishlist has items)",
      "default": "Continue Shopping"
    },
    {
      "type": "header",
      "content": "Empty state"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Heading",
      "default": "Your wishlist is empty"
    },
    {
      "type": "text",
      "id": "empty_body",
      "label": "Text",
      "default": "Save products you love by tapping the heart icon on any product."
    },
    {
      "type": "text",
      "id": "empty_button_label",
      "label": "Button label",
      "default": "Continue Shopping"
    }
  ],
  "presets": [
    {
      "name": "Wishlist Page"
    }
  ]
}
{% endschema %}
