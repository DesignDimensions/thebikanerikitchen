{{ 'custom-blogs_carousal.css' | asset_url | stylesheet_tag }}
<script src="{{ 'gsap.min.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'custom-blogs-carousel.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .custom-blogs-carousel-section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .custom-blogs-carousel-section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- capture chevron_icon -%}
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M14.5 6L9 12L14.5 18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{%- endcapture -%}

<div
  class="custom-blogs-carousel-container custom-blogs-carousel-section-{{ section.id }}-padding"
  id="CustomBlogsCarousel-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  <div class="custom-blogs-carousel-viewport">
    {%- for block in section.blocks -%}
      {%- liquid
        assign loading = 'lazy'
        assign fetch_priority = 'auto'
        if forloop.first
          assign loading = 'eager'
          assign fetch_priority = 'high'
        endif
      -%}
      <div
        class="custom-blogs-carousel-slide{% if forloop.first %} is-active{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="custom-blogs-carousel-media">
          {%- if block.settings.image -%}
            {%- assign img_height = block.settings.image.width
              | divided_by: block.settings.image.aspect_ratio
              | round
            -%}
            {%- assign img_alt = block.settings.image.alt | escape -%}
            {{
              block.settings.image
              | image_url: width: 1500
              | image_tag:
                class: 'custom-blogs-carousel-image',
                alt: img_alt,
                height: img_height,
                loading: loading,
                fetchpriority: fetch_priority,
                sizes: '(min-width: 750px) 50vw, 100vw',
                widths: '375, 550, 750, 1100, 1500, 2000'
            }}
          {%- else -%}
            {%- assign placeholder_index = forloop.index | modulo: 2 -%}
            {%- if placeholder_index == 1 -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-blogs-carousel-image placeholder-svg' }}
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag: 'custom-blogs-carousel-image placeholder-svg' }}
            {%- endif -%}
          {%- endif -%}

          {%- if block.settings.tag_1 != blank -%}
            <p class="custom-blogs-carousel-tag custom-blogs-carousel-tag-1">{{ block.settings.tag_1 }}</p>
          {%- endif -%}
          {%- if block.settings.tag_2 != blank -%}
            <p class="custom-blogs-carousel-tag custom-blogs-carousel-tag-2">{{ block.settings.tag_2 }}</p>
          {%- endif -%}
          {%- if block.settings.tag_3 != blank -%}
            <p class="custom-blogs-carousel-tag custom-blogs-carousel-tag-3">{{ block.settings.tag_3 }}</p>
          {%- endif -%}
        </div>

        <div class="custom-blogs-carousel-content">
          {%- if block.settings.caption != blank or section.blocks.size > 1 -%}
            <div class="custom-blogs-carousel-meta">
              {%- if block.settings.caption != blank -%}
                <p class="custom-blogs-carousel-caption">{{ block.settings.caption }}</p>
              {%- endif -%}
              {%- if section.blocks.size > 1 -%}
                <p class="custom-blogs-carousel-counter">
                  <span>{{ forloop.index }}</span><span>|</span><span>{{ section.blocks.size }}</span>
                </p>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if block.settings.heading != blank -%}
            <h2 class="custom-blogs-carousel-heading">{{ block.settings.heading }}</h2>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <div class="custom-blogs-carousel-description rte">{{ block.settings.description }}</div>
          {%- endif -%}

          {%- if block.settings.cta_text != blank -%}
            <a href="{{ block.settings.link }}" class="custom-blogs-carousel-cta">
              <span class="custom-blogs-carousel-cta-text">{{ block.settings.cta_text }}</span>
              <span class="custom-blogs-carousel-cta-arrow">
                <img
                  src="https://cdn.shopify.com/s/files/1/0764/0953/6706/files/Vector_22_1.png?v=1783513087"
                  alt=""
                  class="custom-blogs-carousel-cta-arrow-icon"
                  width="20"
                  height="20"
                  loading="lazy"
                >
              </span>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- else -%}
      {%- if request.design_mode -%}
        <div class="custom-blogs-carousel-slide is-active">
          <div class="custom-blogs-carousel-media">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'custom-blogs-carousel-image placeholder-svg' }}
          </div>
          <div class="custom-blogs-carousel-content">
            <h2 class="custom-blogs-carousel-heading">Add a story block to get started</h2>
            <div class="custom-blogs-carousel-description">
              <p>Use “Add block” in the section settings to add your first blog story.</p>
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    <button
      type="button"
      class="custom-blogs-carousel-nav custom-blogs-carousel-nav-prev"
      aria-label="{{ 'general.slider.previous_slide' | t }}"
      aria-controls="CustomBlogsCarousel-{{ section.id }}"
    >
      <span class="custom-blogs-carousel-nav-icon">{{ chevron_icon }}</span>
    </button>
    <button
      type="button"
      class="custom-blogs-carousel-nav custom-blogs-carousel-nav-next"
      aria-label="{{ 'general.slider.next_slide' | t }}"
      aria-controls="CustomBlogsCarousel-{{ section.id }}"
    >
      <span class="custom-blogs-carousel-nav-icon">{{ chevron_icon }}</span>
    </button>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Custom Blogs Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Story",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Tags on image"
        },
        {
          "type": "text",
          "id": "tag_1",
          "label": "Tag — top left",
          "default": "Culture"
        },
        {
          "type": "text",
          "id": "tag_2",
          "label": "Tag — center",
          "default": "Techniques"
        },
        {
          "type": "text",
          "id": "tag_3",
          "label": "Tag — bottom right",
          "default": "Traditions"
        },
        {
          "type": "header",
          "content": "Story content"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Rituals"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The Discipline of Marwadi Kitchens"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_text",
          "label": "Button label",
          "default": "Read More"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Blog post link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Blogs Carousel",
      "blocks": [{ "type": "slide" }, { "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
