{{ 'custom-press-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .press-banner {
    background-color: {{ section.settings.background_color }};
    min-height: {{ section.settings.min_height }}px;
  }

  #shopify-section-{{ section.id }} .press-banner__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .press-banner__content {
    color: {{ section.settings.text_color }};
  }
{%- endstyle -%}

<div class="press-banner">
  {%- if section.settings.background_image != blank -%}
    <img
      src="{{ section.settings.background_image | image_url: width: 2600 }}"
      srcset="{{ section.settings.background_image | image_url: width: 1200 }} 1200w, {{ section.settings.background_image | image_url: width: 2600 }} 2600w"
      sizes="100vw"
      alt=""
      class="press-banner__bg"
      loading="lazy"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
    >
    <div class="press-banner__overlay"></div>
  {%- endif -%}

  <div class="press-banner__content">
    {%- if section.settings.eyebrow != blank -%}
      <p class="press-banner__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="press-banner__heading section-heading{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="press-banner__body rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
        {{ section.settings.body }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Press Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Featured In"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lorem ipsum dolor sit amet consectetur."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Lorem ipsum dolor sit amet consectetur. Rhoncus semper a eu lectus viverra nunc eget ligula. Purus auctor id vitae amet massa neque pharetra.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#c0a959"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#181818"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "label": "Minimum height",
      "default": 420
    }
  ],
  "presets": [
    {
      "name": "Press Banner"
    }
  ]
}
{% endschema %}
