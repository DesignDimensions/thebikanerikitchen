{{ 'custom-404.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} .error-404 {
    background-color: {{ section.settings.background_color }};
  }

  #shopify-section-{{ section.id }} .error-404__overlay {
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }

  #shopify-section-{{ section.id }} .error-404__card {
    background-color: {{ section.settings.card_background_color }};
    color: {{ section.settings.text_color }};
  }

  #shopify-section-{{ section.id }} .error-404__button {
    background-color: {{ section.settings.button_background_color }};
    color: {{ section.settings.button_text_color }};
  }
{%- endstyle -%}

<div class="error-404">
  {%- if section.settings.background_image != blank -%}
    <img
      src="{{ section.settings.background_image | image_url: width: 2600 }}"
      srcset="{{ section.settings.background_image | image_url: width: 1200 }} 1200w, {{ section.settings.background_image | image_url: width: 2600 }} 2600w"
      sizes="100vw"
      alt=""
      class="error-404__bg"
      loading="lazy"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
    >
    <div class="error-404__overlay"></div>
  {%- endif -%}

  <div class="error-404__card">
    {%- if section.settings.eyebrow != blank -%}
      <p class="error-404__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="error-404__heading section-heading">
        {{ section.settings.heading | newline_to_br }}
      </h1>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="error-404__subtext">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: routes.root_url }}" class="error-404__button">
        {{ section.settings.button_label | escape }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "404 Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image overlay opacity",
      "default": 0
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Oh No!"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "info": "Press Enter/Return to force a line break.",
      "default": "Error 404\nPage Not Found."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "We suggest you to visit out homepage."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Lorem Ipsum Doret Si"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Defaults to the homepage when left blank."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#181818"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background color",
      "default": "#fffdee"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Card text color",
      "default": "#181818"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "Button background color",
      "default": "#181818"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#fffdee"
    }
  ],
  "presets": [
    {
      "name": "404 Banner"
    }
  ]
}
{% endschema %}
