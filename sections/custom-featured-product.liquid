{{ 'custom-featured-product.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

<div class="custom-featured-product-container">
  <img
    src="{{ section.settings.bg_left_image | image_url }}"
    alt="{{ section.settings.bg_left_image.alt | escape }}"
    width="{{ section.settings.bg_left_image.width }}"
    height="{{ section.settings.bg_left_image.height }}"
  >
  <img
    src="{{ section.settings.bg_right_image | image_url }}"
    alt="{{ section.settings.bg_right_image.alt | escape }}"
    width="{{ section.settings.bg_right_image.width }}"
    height="{{ section.settings.bg_right_image.height }}"
  >
  {% assign product = section.settings.featured_product %}
  {% assign featured_variant = product.selected_or_first_available_variant %}
  {% if featured_variant == null and product != blank %}
    {% assign featured_variant = product.variants.first %}
  {% endif %}
  <div class="page-width">
    <div class="custom-featured-product-left">
      <img
        src="{{ section.settings['featured-product-left-bg'] | image_url }}"
        alt="{{ section.settings['featured-product-left-bg'].alt | escape }}"
        width="{{ section.settings['featured-product-left-bg'].width }}"
        height="{{ section.settings['featured-product-left-bg'].height }}"
      >
      <div class="custom-featured-product-left-inner_upper">
        <p>{{ section.settings.top_left_caption }}</p>
        <p>{{ section.settings.heading }}</p>
        <div class="custom-featured-product-left-description">
          <p>{{ section.settings.description }}</p>
        </div>
      </div>
      <div class="custom-featured-product-left-inner_lower">
        <p>{{ section.settings.size }}</p>
        <div class="custom-featured-product-left-cta_container">
          <img
            src="{{ section.settings.icon | image_url }}"
            alt="{{ section.settings.icon.alt | escape }}"
            width="{{ section.settings.icon.width }}"
            height="{{ section.settings.icon.height }}"
          >
          {% if product != blank and featured_variant != null %}
            {% assign product_form_id = 'custom-featured-product-form-' | append: section.id %}
            <product-form class="product-form" data-hide-errors="false" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="product-form__error-message"></span>
              </div>
              {%- form 'product', product, id: product_form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                <input type="hidden" name="id" value="{{ featured_variant.id }}" class="product-variant-id">
                <input type="hidden" name="quantity" value="1">
                <div class="product-form__buttons">
                  <button
                    type="submit"
                    name="add"
                    class="product-form__submit custom-featured-product__cta"
                    {% unless featured_variant.available %}
                      disabled
                    {% endunless %}
                  >
                    <span class="custom-featured-product__button-text">
                      {% if featured_variant.available %}
                        {{ section.settings.cta }}
                      {% else %}
                        Sold out
                      {% endif %}
                    </span>
                    {% render 'loading-spinner' %}
                  </button>
                </div>
              {%- endform -%}
            </product-form>
          {% else %}
            <button type="button" disabled>{{ section.settings.cta }}</button>
          {% endif %}
        </div>
      </div>
    </div>
    <div class="custom-featured-product-right">
      <hr>
      <p>{{ section.settings.top_right_caption }}</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Custom Featured Product",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    },
    {
      "type": "image_picker",
      "id": "bg_left_image",
      "label": "Background Left Image"
    },
    {
      "type": "image_picker",
      "id": "bg_right_image",
      "label": "Background Right Image"
    },
    {
      "type": "image_picker",
      "id": "featured-product-left-bg",
      "label": "Featured Product Left Background"
    },
    {
      "type": "text",
      "id": "top_left_caption",
      "label": "Top Left Caption"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "size",
      "label": "Size"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon"
    },
    {
      "type": "text",
      "id": "cta",
      "label": "CTA Text"
    },
    {
      "type": "text",
      "id": "top_right_caption",
      "label": "Top Right Caption"
    }
  ],
  "presets": [
    {
      "name": "Custom Featured Product"
    }
  ]
}
{% endschema %}
