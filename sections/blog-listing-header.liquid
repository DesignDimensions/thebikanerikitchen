{{ 'blog-listing-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'blog-listing-header.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .blog-listing-header-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .blog-listing-header-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="blog-listing-header blog-listing-header-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
  style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
>
  <div class="page-width blog-listing-header-inner">
    <div class="blog-listing-header-col blog-listing-header-col--heading">
      {%- if section.settings.heading != blank -%}
        <h2 class="blog-listing-header-heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="blog-listing-header-col blog-listing-header-col--content">
      {%- if section.settings.title != blank -%}
        <h3 class="blog-listing-header-title">{{ section.settings.title }}</h3>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="blog-listing-header-description-wrap">
          <div class="blog-listing-header-description rte">
            {{ section.settings.description }}
          </div>
        </div>
      {%- endif -%}
    </div>

    <div class="blog-listing-header-col blog-listing-header-col--action">
      {%- if section.settings.description != blank -%}
        <a href="#" class="blog-listing-header-toggle" data-read-more-link hidden>
          <span class="blog-listing-header-toggle-label">{{ section.settings.read_more_label }}</span>
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blog Listing Header",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Rituals"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Desert Never Wasted Anything"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Lorem ipsum dolor sit amet consectetur. Nisi risus in egestas tellus risus neque fermentum vestibule vitae.</p>"
    },
    {
      "type": "text",
      "id": "read_more_label",
      "label": "Read more label",
      "default": "Read More"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#C0A959"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFDEE"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Blog Listing Header"
    }
  ]
}
{% endschema %}
