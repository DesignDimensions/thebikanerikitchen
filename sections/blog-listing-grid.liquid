{{ 'blog-listing-grid.css' | asset_url | stylesheet_tag }}
<script src="{{ 'blog-listing-grid.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .blog-listing-grid-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .blog-listing-grid-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="blog-listing-grid blog-listing-grid-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
  style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }}; --blog-listing-grid-bg: {{ section.settings.background_color }};"
>
  <div class="page-width blog-listing-grid-inner">
    {%- if section.settings.subtitle != blank or section.settings.title != blank or section.settings.description != blank -%}
      <div class="blog-listing-grid-heading">
        {%- if section.settings.subtitle != blank -%}
          <p class="blog-listing-grid-subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="blog-listing-grid-title">{{ section.settings.title | newline_to_br }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="blog-listing-grid-description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign pill_blocks = section.blocks | where: 'type', 'pill' -%}
    {%- if pill_blocks.size > 0 -%}
      <div class="blog-listing-grid-filters" data-filters>
        {%- for block in pill_blocks -%}
          {%- if block.settings.title != blank -%}
            <button
              type="button"
              class="blog-listing-grid-filter"
              data-filter-tag="{{ block.settings.tag | escape }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.title }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.blog != blank -%}
      {%- assign blog = section.settings.blog -%}
      {%- paginate blog.articles by section.settings.posts_to_show -%}
        <div class="blog-listing-grid-list">
          {%- for article in blog.articles -%}
            {%- liquid
              assign global_index = paginate.current_offset | plus: forloop.index
              assign padded_index = '00' | append: global_index | slice: -3, 3
            -%}
            <div
              class="blog-listing-grid-item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
              data-tags="{{ article.tags | join: ',' | escape }}"
              {% if settings.animations_reveal_on_scroll %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
            >
              <a href="{{ article.url }}" class="blog-listing-grid-item-link">
                <div class="blog-listing-grid-item-media">
                  {%- if article.image -%}
                    {%- assign image_alt = article.image.alt | escape -%}
                    {{
                      article.image
                      | image_url: width: 1600
                      | image_tag:
                        class: 'blog-listing-grid-item-image',
                        alt: image_alt,
                        loading: 'lazy',
                        sizes: '(min-width: 750px) 70vw, 100vw',
                        widths: '375, 550, 750, 1100, 1500, 2000'
                    }}
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'blog-listing-grid-item-image placeholder-svg' }}
                  {%- endif -%}

                  <div class="blog-listing-grid-item-scrim"></div>

                  <div class="blog-listing-grid-item-text">
                    <p class="blog-listing-grid-item-index">{{ padded_index }}</p>
                    <h3 class="blog-listing-grid-item-title">{{ article.title }}</h3>
                  </div>

                  <div class="blog-listing-grid-item-icons">
                    {%- if section.settings.star_icon -%}
                      <img
                        src="{{ section.settings.star_icon | image_url: width: 80 }}"
                        alt=""
                        class="blog-listing-grid-item-icon blog-listing-grid-item-icon--star"
                        loading="lazy"
                        width="28"
                        height="28"
                      >
                    {%- endif -%}
                    {%- if section.settings.arrow_icon -%}
                      <img
                        src="{{ section.settings.arrow_icon | image_url: width: 240 }}"
                        alt=""
                        class="blog-listing-grid-item-icon blog-listing-grid-item-icon--arrow"
                        loading="lazy"
                        width="120"
                        height="24"
                      >
                    {%- endif -%}
                  </div>
                </div>
              </a>
            </div>
          {%- else -%}
            {%- if request.design_mode -%}
              <div class="blog-listing-grid-item">
                <div class="blog-listing-grid-item-media">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'blog-listing-grid-item-image placeholder-svg' }}
                  <div class="blog-listing-grid-item-scrim"></div>
                  <div class="blog-listing-grid-item-text">
                    <p class="blog-listing-grid-item-index">001</p>
                    <h3 class="blog-listing-grid-item-title">This blog has no posts yet</h3>
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          {%- render 'pagination', paginate: paginate -%}
        {%- endif -%}
      {%- endpaginate -%}
    {%- elsif request.design_mode -%}
      <div class="blog-listing-grid-empty-state">
        <p>Select a blog in the section settings to populate this grid with its posts.</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Blog Listing Grid",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "info": "Press Enter/Return to force a line break."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Posts"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "label": "Posts per page",
      "min": 3,
      "max": 24,
      "step": 3,
      "default": 6
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "image_picker",
      "id": "star_icon",
      "label": "Star icon"
    },
    {
      "type": "image_picker",
      "id": "arrow_icon",
      "label": "Arrow icon"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFDEE"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFDEE"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Filter Pill",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Pill label"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Filter tag",
          "info": "Must match a tag on your blog posts exactly."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog Listing Grid"
    }
  ]
}
{% endschema %}
